# Environment settings
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-at-least-32-chars-long

# Database (MongoDB)
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/WEB_CRAWL?appName=Cluster0

# Redis (Upstash)
REDIS_URL=rediss://default:<token>@<endpoint>.upstash.io:6379

# Celery (Upstash Redis)
CELERY_BROKER_URL=rediss://default:<token>@<endpoint>.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:<token>@<endpoint>.upstash.io:6379

# JWT Auth
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Crawler Settings
CRAWLER_MAX_WORKERS=32
CRAWLER_TIMEOUT_SECONDS=30
CRAWLER_RESPECT_ROBOTS_TXT=true
CRAWLER_FOLLOW_REDIRECTS=true

# Sitemap Discovery Settings
SITEMAP_DISCOVERY_TIMEOUT=10
SITEMAP_MAX_DEPTH=10
SITEMAP_MAX_URLS_PER_SITEMAP=50000

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
